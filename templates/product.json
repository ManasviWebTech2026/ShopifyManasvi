        "custom_liquid_F9AkP3": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% if product.metafields.custom.product_tab_information != blank %}\n\n<script>\nwindow.variantSpecs = {{ product.metafields.custom.product_tab_information.value | json }};\n</script>\n\n<div class=\"product-info-wrapper\">\n\n  <!-- LEFT SIDE -->\n\n  <div class=\"product-tabs-column\">\n\n```\n<div class=\"custom-tabs-nav\">\n  <button class=\"tab-btn active\" data-tab=\"description\">\n    Description\n  </button>\n\n  <button class=\"tab-btn\" data-tab=\"love\">\n    Why You'll Love It\n  </button>\n\n  <button class=\"tab-btn\" data-tab=\"care\">\n    Clean & Care\n  </button>\n</div>\n\n<div class=\"custom-tab-content\">\n\n  <div class=\"tab-panel active\" id=\"description-tab\">\n    <div id=\"tab-description\"></div>\n  </div>\n\n  <div class=\"tab-panel\" id=\"love-tab\">\n    <div id=\"tab-love\"></div>\n  </div>\n\n  <div class=\"tab-panel\" id=\"care-tab\">\n    <div id=\"tab-care\"></div>\n  </div>\n\n</div>\n```\n\n  </div>\n\n  <!-- RIGHT SIDE -->\n\n  <div class=\"product-specs-column\">\n\n```\n<div class=\"specs-card\">\n\n  <h2>Specs & Materials</h2>\n\n  <div class=\"spec-row\">\n    <div class=\"spec-label\">Dimensions:</div>\n    <div class=\"spec-value\" id=\"spec-dimensions\">-</div>\n  </div>\n\n  <div class=\"spec-row\">\n    <div class=\"spec-label\">Weight:</div>\n    <div class=\"spec-value\" id=\"spec-weight\">-</div>\n  </div>\n\n  <div class=\"spec-row\">\n    <div class=\"spec-label\">Design:</div>\n    <div class=\"spec-value\" id=\"spec-design\">-</div>\n  </div>\n\n  <div class=\"spec-row\">\n    <div class=\"spec-label\">Perfect For:</div>\n    <div class=\"spec-value\" id=\"spec-perfect-for\">-</div>\n  </div>\n\n  <div class=\"spec-row\">\n    <div class=\"spec-label\">Style & Function:</div>\n    <div class=\"spec-value\" id=\"spec-style\">-</div>\n  </div>\n\n  <div class=\"spec-row\">\n    <div class=\"spec-label\">Material:</div>\n    <div class=\"spec-value\" id=\"spec-material\">-</div>\n  </div>\n\n  <div class=\"spec-row\">\n    <div class=\"spec-label\">Sold As:</div>\n    <div class=\"spec-value\" id=\"spec-sold-as\">-</div>\n  </div>\n\n</div>\n```\n\n  </div>\n\n</div>\n\n<style>\n.product-info-wrapper{\n  display:grid;\n  grid-template-columns:1.2fr .8fr;\n  gap:60px;\n  margin-top:40px;\n}\n\n.custom-tabs-nav{\n  display:flex;\n  gap:12px;\n  flex-wrap:wrap;\n  margin-bottom:25px;\n}\n\n.tab-btn{\n  border:1px solid #ddd;\n  background:#fff;\n  padding:14px 24px;\n  border-radius:40px;\n  cursor:pointer;\n  transition:.3s;\n}\n\n.tab-btn.active{\n  background:#111;\n  color:#fff;\n  border-color:#111;\n}\n\n.tab-panel{\n  display:none;\n}\n\n.tab-panel.active{\n  display:block;\n}\n\n.custom-tab-content{\n  line-height:1.8;\n}\n\n.specs-card{\n  background:#f5f3f3;\n  border-radius:24px;\n  padding:35px;\n}\n\n.specs-card h2{\n  margin:0 0 25px;\n  font-size:40px;\n}\n\n.spec-row{\n  display:grid;\n  grid-template-columns:180px 1fr;\n  gap:15px;\n  padding:18px 0;\n  border-bottom:1px solid #e4e4e4;\n}\n\n.spec-row:last-child{\n  border-bottom:none;\n}\n\n.spec-label{\n  font-weight:600;\n}\n\n.spec-value{\n  color:#666;\n}\n\n@media(max-width:989px){\n  .product-info-wrapper{\n    grid-template-columns:1fr;\n    gap:30px;\n  }\n\n  .specs-card h2{\n    font-size:28px;\n  }\n\n  .spec-row{\n    grid-template-columns:120px 1fr;\n  }\n}\n</style>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function(){\n\n  function updateSpecs(){\n\n    if(!window.variantSpecs) return;\n\n    let thickness = '';\n    let size = '';\n\n    const selectedOptions = document.querySelectorAll(\n      '.avpoptions-container__v2 input:checked, .avpoptions-container__v2 .selected'\n    );\n\n    selectedOptions.forEach(function(option){\n\n      const value = option.value || option.textContent || '';\n\n      if(\n        value.includes('2mm') ||\n        value.includes('5mm') ||\n        value.includes('7mm')\n      ){\n        thickness = value.trim();\n      }\n\n      if(\n        value.includes('183cm') ||\n        value.includes('200cm') ||\n        value.includes('135cm')\n      ){\n        size = value.trim();\n      }\n\n    });\n\n    if(!thickness || !size) return;\n\n    const spec = window.variantSpecs?.[thickness]?.[size];\n\n    if(!spec) return;\n\n    document.getElementById('tab-description').innerHTML =\n      spec.description || '';\n\n    document.getElementById('tab-love').innerHTML =\n      spec.why_love_it || '';\n\n    document.getElementById('tab-care').innerHTML =\n      spec.clean_care || '';\n\n    document.getElementById('spec-dimensions').textContent =\n      spec.dimensions || '-';\n\n    document.getElementById('spec-weight').textContent =\n      spec.weight || '-';\n\n    document.getElementById('spec-design').textContent =\n      spec.design || '-';\n\n    document.getElementById('spec-perfect-for').textContent =\n      spec.perfect_for || '-';\n\n    document.getElementById('spec-style').textContent =\n      spec.style || '-';\n\n    document.getElementById('spec-material').textContent =\n      spec.material || '-';\n\n    document.getElementById('spec-sold-as').textContent =\n      spec.sold_as || '-';\n  }\n\n  setTimeout(updateSpecs, 1000);\n\n  document.addEventListener('click', function(){\n    setTimeout(updateSpecs, 200);\n  });\n\n  document.addEventListener('change', function(){\n    setTimeout(updateSpecs, 200);\n  });\n\n  document.querySelectorAll('.tab-btn').forEach(function(btn){\n\n    btn.addEventListener('click', function(){\n\n      document.querySelectorAll('.tab-btn').forEach(function(b){\n        b.classList.remove('active');\n      });\n\n      document.querySelectorAll('.tab-panel').forEach(function(p){\n        p.classList.remove('active');\n      });\n\n      btn.classList.add('active');\n\n      if(btn.dataset.tab === 'description'){\n        document.getElementById('description-tab').classList.add('active');\n      }\n\n      if(btn.dataset.tab === 'love'){\n        document.getElementById('love-tab').classList.add('active');\n      }\n\n      if(btn.dataset.tab === 'care'){\n        document.getElementById('care-tab').classList.add('active');\n      }\n\n    });\n\n  });\n\n});\n</script>\n\n{% endif %}"
