          "settings": {
            "custom_liquid": "{% if product.metafields.custom.product_tab_information != blank %}\n\n<script>\nwindow.variantSpecs = {{ product.metafields.custom.product_tab_information.value | json }};\n</script>\n\n<div class=\"specs-materials\">\n  <h3>Specs & Materials</h3>\n\n  <div class=\"spec-row\">\n    <div class=\"spec-label\">Dimensions:</div>\n    <div class=\"spec-value\" id=\"spec-dimensions\">-</div>\n  </div>\n\n  <div class=\"spec-row\">\n    <div class=\"spec-label\">Weight:</div>\n    <div class=\"spec-value\" id=\"spec-weight\">-</div>\n  </div>\n\n  <div class=\"spec-row\">\n    <div class=\"spec-label\">Design:</div>\n    <div class=\"spec-value\" id=\"spec-design\">-</div>\n  </div>\n\n  <div class=\"spec-row\">\n    <div class=\"spec-label\">Perfect For:</div>\n    <div class=\"spec-value\" id=\"spec-perfect-for\">-</div>\n  </div>\n\n  <div class=\"spec-row\">\n    <div class=\"spec-label\">Style & Function:</div>\n    <div class=\"spec-value\" id=\"spec-style\">-</div>\n  </div>\n\n  <div class=\"spec-row\">\n    <div class=\"spec-label\">Material:</div>\n    <div class=\"spec-value\" id=\"spec-material\">-</div>\n  </div>\n\n  <div class=\"spec-row\">\n    <div class=\"spec-label\">Sold As:</div>\n    <div class=\"spec-value\" id=\"spec-sold-as\">-</div>\n  </div>\n</div>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function () {\n\n  function updateSpecs() {\n\n    if (!window.variantSpecs) return;\n\n    let thickness = '';\n    let size = '';\n\n    const selectedOptions = document.querySelectorAll(\n      '.avpoptions-container__v2 input:checked, .avpoptions-container__v2 .selected'\n    );\n\n    selectedOptions.forEach(function(option){\n\n      const value = option.value || option.innerText || '';\n\n      if (\n        value.includes('2mm') ||\n        value.includes('5mm') ||\n        value.includes('7mm')\n      ) {\n        thickness = value.trim();\n      }\n\n      if (\n        value.includes('183cm') ||\n        value.includes('200cm') ||\n        value.includes('135cm')\n      ) {\n        size = value.trim();\n      }\n\n    });\n\n    if (!thickness || !size) return;\n\n    const spec =\n      window.variantSpecs?.[thickness]?.[size];\n\n    if (!spec) return;\n\n    document.getElementById('spec-dimensions').textContent =\n      spec.dimensions || '-';\n\n    document.getElementById('spec-weight').textContent =\n      spec.weight || '-';\n\n    document.getElementById('spec-design').textContent =\n      spec.design || '-';\n\n    document.getElementById('spec-perfect-for').textContent =\n      spec.perfect_for || '-';\n\n    document.getElementById('spec-style').textContent =\n      spec.style || '-';\n\n    document.getElementById('spec-material').textContent =\n      spec.material || '-';\n\n    document.getElementById('spec-sold-as').textContent =\n      spec.sold_as || '-';\n  }\n\n  setTimeout(updateSpecs, 1000);\n\n  document.addEventListener('click', function() {\n    setTimeout(updateSpecs, 300);\n  });\n\n  document.addEventListener('change', function() {\n    setTimeout(updateSpecs, 300);\n  });\n\n});\n</script>\n\n<style>\n.specs-materials{\n  margin-top:30px;\n}\n.spec-row{\n  display:flex;\n  gap:15px;\n  padding:10px 0;\n  border-bottom:1px solid #eee;\n}\n.spec-label{\n  min-width:150px;\n  font-weight:600;\n}\n.spec-value{\n  flex:1;\n}\n</style>\n\n{% endif %}"
